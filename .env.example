# Financial News App Environment Configuration
# Copy this file to `.env` and edit values as needed.

# -------------------------------
# Backend (FastAPI + ingestion)
# -------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financenews
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financenews

# Optional operation-specific database URLs
STAGING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financenews_staging
DRILL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financenews_drill
RESTORE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financenews_restore

# Auto-refresh frequency in seconds (0 disables periodic ingest)
NEWS_INGEST_INTERVAL_SECONDS=0

# Enable fetching full article content when RSS snippets are short
NEWS_INGEST_ENABLE_FULL_TEXT_FETCH=true

# Comma-separated RSS/Atom feeds.
NEWS_INGEST_FEEDS=https://www.reuters.com/tools/rss,https://www.cnbc.com/id/100003114/device/rss/rss.html,https://feeds.bbci.co.uk/news/business/rss.xml,https://news.google.com/rss/search?q=financial+news&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=capital+markets&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=artificial+intelligence+finance+markets&hl=en-US&gl=US&ceid=US:en

# Optional SEC public sources / API controls
SEC_PRESS_RELEASE_FEEDS=https://www.sec.gov/newsroom/press-releases/rss?output=atom
SEC_API_BASE_URL=https://data.sec.gov
SEC_API_USER_AGENT=your-name-your-email@example.com
SEC_API_REQUEST_DELAY_SECONDS=1

# -------------------------------
# Frontend API URLs
# -------------------------------
REACT_APP_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000
FASTAPI_URL=http://127.0.0.1:8000

# Reliability controls for Next.js API proxy
ENABLE_LOCAL_API_FALLBACK=true
FASTAPI_REQUEST_TIMEOUT_MS=8000
FASTAPI_GET_RETRIES=1
FASTAPI_ADMIN_API_KEY=

# -------------------------------
# Continuous ingestion controls
# -------------------------------
CONTINUOUS_INGEST_ENABLED=true
CONTINUOUS_INGEST_INTERVAL_SECONDS=300

GDELT_ENABLED=true
SEC_EDGAR_ENABLED=true
NEWSDATA_ENABLED=true
NEWSDATA_API_KEY=

# -------------------------------
# Reddit connector (controlled rollout)
# -------------------------------
REDDIT_ENABLED=false
REDDIT_SUBREDDITS=investing,stocks,stockmarket,economics,wallstreetbets
REDDIT_MAX_ARTICLES=25
REDDIT_SORT=hot
REDDIT_PRECISION_THRESHOLD=0.35
REDDIT_RATE_BUDGET_PER_HOUR=120

# -------------------------------
# Ranking + dedup rollout controls
# -------------------------------
FEED_RANKING_V2_ENABLED=true
FEED_RANKING_V2_CANDIDATE_MULTIPLIER=5
FEED_RANKING_V2_MAX_CANDIDATES=500
FEED_RANKING_V2_DEDUP_ENABLED=true
FEED_NEAR_DEDUP_ENABLED=true
FEED_NEAR_DEDUP_SIMILARITY_THRESHOLD=0.92

# -------------------------------
# Optional enrichment controls
# -------------------------------
STOCK_CORRELATION_ENABLED=false
# Backward-compatible alias for older environments
STOCK_CORRELATOR_ENABLED=false

# -------------------------------
# Admin endpoint controls
# -------------------------------
# If ADMIN_API_KEY is empty, admin auth is relaxed for local development.
ADMIN_API_KEY=
ADMIN_ALLOWED_ROLES=admin,ops
ADMIN_RATE_LIMIT_PER_MINUTE=30
